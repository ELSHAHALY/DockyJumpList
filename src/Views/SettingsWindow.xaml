<Window x:Class="DockyJumpList.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Docky Jump List — Settings"
        Width="600" Height="620"
        MinWidth="520" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1E"
        Foreground="#F0F0F5"
        ResizeMode="CanResize"
        FontFamily="Segoe UI"
        FontSize="13">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#141416" BorderBrush="#2C2C30" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Border Width="26" Height="26" CornerRadius="6" Background="#0078D4" Margin="0,0,10,0">
                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                </Border>
                <TextBlock Text="Docky Jump List" FontSize="15" FontWeight="SemiBold"
                           Foreground="#F0F0F5" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab strip -->
        <Border Grid.Row="1" Background="#141416" BorderBrush="#2C2C30" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Bottom">
                <Button x:Name="BtnTabShortcuts" Content="Shortcuts"
                        Style="{StaticResource TabButton}"
                        Tag="shortcuts"
                        Click="TabButton_Click" Margin="0,0,2,0"/>
                <Button x:Name="BtnTabPrefs" Content="Preferences"
                        Style="{StaticResource TabButton}"
                        Tag="prefs"
                        Click="TabButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">

            <!-- SHORTCUTS TAB -->
            <Grid x:Name="PanelShortcuts">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" Margin="14,12,8,8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="+ Add"    Style="{StaticResource PrimaryButton}"
                                Command="{Binding NewShortcutCommand}"    Margin="0,0,6,0"/>
                        <Button Content="Edit"     Style="{StaticResource SecondaryButton}"
                                Command="{Binding EditShortcutCommand}"   Margin="0,0,6,0"/>
                        <Button Content="Remove"   Style="{StaticResource DangerButton}"
                                Command="{Binding RemoveShortcutCommand}"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom" Text="Drag rows to reorder"
                               FontSize="10" Foreground="#44445A" Margin="0,6,0,0"/>

                    <ListBox x:Name="ShortcutList"
                             ItemsSource="{Binding Shortcuts}"
                             SelectedItem="{Binding SelectedShortcut}"
                             Background="#232325"
                             BorderBrush="#2C2C30"
                             BorderThickness="1"
                             Foreground="#F0F0F5"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="List_PreviewMouseMove"
                             Drop="List_Drop"
                             DragOver="List_DragOver">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="38">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="22" Height="22" CornerRadius="5"
                                            Margin="4,0" Background="{Binding TypeBadgeColor}">
                                        <TextBlock Text="{Binding TypeIcon}" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="White"/>
                                    </Border>
                                    <Image Grid.Column="1" Source="{Binding IconSource}"
                                           Width="16" Height="16" Margin="0,0,4,0"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DisplayName}"
                                               VerticalAlignment="Center" Foreground="#F0F0F5"
                                               FontSize="13" TextTrimming="CharacterEllipsis" Margin="2,0"/>
                                    <TextBlock Grid.Column="3" Text=":::" FontSize="12"
                                               Foreground="#44445A" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Cursor="SizeAll"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2C2C38"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#26262C"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>

                <Border Grid.Column="0" HorizontalAlignment="Right" Width="1"
                        Background="#2C2C30" Margin="0,12,0,8"/>

                <StackPanel Grid.Column="1" Margin="12,12,16,8">
                    <TextBlock Text="{Binding FormTitle}" FontWeight="SemiBold" FontSize="11"
                               Foreground="#88889A" Margin="0,0,0,12"/>

                    <TextBlock Text="Display Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}" Margin="0,4,0,10"/>

                    <TextBlock Text="Target (Path or URL)" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,4,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding FormTarget, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputBox}" Margin="0,0,5,0"/>
                        <Button Content="..." Style="{StaticResource BrowseButton}"
                                Command="{Binding BrowseCommand}"
                                ToolTip="Browse for .exe" Grid.Column="1"/>
                    </Grid>

                    <TextBlock Text="Arguments (optional)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FormArguments, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputBox}" Margin="0,4,0,14"/>

                    <Button Content="Save Shortcut" Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveFormCommand}"
                            HorizontalAlignment="Stretch" Height="36"/>
                    <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Command="{Binding CancelFormCommand}"
                            HorizontalAlignment="Stretch" Height="30" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- PREFERENCES TAB -->
            <StackPanel x:Name="PanelPrefs" Margin="24,16" Visibility="Collapsed">

                <TextBlock Text="SYSTEM" Foreground="#55556A" FontSize="10"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>

                <Border Background="#232325" CornerRadius="8" Padding="14,12" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Launch on Windows startup" Foreground="#F0F0F5" FontSize="13"/>
                            <TextBlock Text="Start automatically after login"
                                       Foreground="#55556A" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding LaunchOnStartup}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Background="#232325" CornerRadius="8" Padding="14,12" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Show app icons in jump list" Foreground="#F0F0F5" FontSize="13"/>
                            <TextBlock Text="Loads icons from .exe files (tiny delay on first open)"
                                       Foreground="#55556A" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding ShowIconsInMenu}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock Text="GLOBAL HOTKEY" Foreground="#55556A" FontSize="10"
                           FontWeight="SemiBold" Margin="0,20,0,6"/>

                <Border Background="#232325" CornerRadius="8" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Show jump list from anywhere" Foreground="#F0F0F5" FontSize="13"/>
                            <TextBlock Text="Press this to open the menu instantly"
                                       Foreground="#55556A" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1A1A20" CornerRadius="6"
                                BorderBrush="#3A3A48" BorderThickness="1"
                                Padding="10,5" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HotkeyLabel}"
                                       Foreground="#0078D4" FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Consolas"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Foreground="#44445A" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                           Text="To change the hotkey, edit HotkeyModifiers and HotkeyVirtualKey in settings.json and restart."/>
            </StackPanel>

        </Grid>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#141416" BorderBrush="#2C2C30" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <TextBlock Text="Saved to %AppData%\DockyJumpList"
                           Foreground="#44445A" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Text="v1.0.0" Foreground="#33334A" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
